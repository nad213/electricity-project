# AWS Configuration
AWS_S3_REGION=eu-west-3
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
# Laisser vide pour AWS. Pour un stockage S3-compatible (ex. Scaleway) :
# AWS_S3_ENDPOINT_URL=https://s3.fr-par.scw.cloud
# ⚠️ AWS_S3_REGION doit alors correspondre à l'endpoint (fr-par pour Scaleway),
# sinon 403 SignatureDoesNotMatch (la région fait partie de la signature SigV4).
AWS_S3_ENDPOINT_URL=

# S3 Paths (update with your bucket name)
S3_PATH_PUISSANCE=s3://your-bucket-name/02_clean/consommation_france_puissance.parquet
S3_PATH_ANNUEL=s3://your-bucket-name/02_clean/consommation_annuelle.parquet
S3_PATH_MENSUEL=s3://your-bucket-name/02_clean/consommation_mensuelle.parquet
S3_PATH_PRODUCTION=s3://your-bucket-name/02_clean/production_france_detail.parquet
S3_PATH_PRODUCTION_ANNUEL=s3://your-bucket-name/02_clean/production_annuelle.parquet
S3_PATH_PRODUCTION_MENSUEL=s3://your-bucket-name/02_clean/production_mensuelle.parquet
S3_PATH_ECHANGES=s3://your-bucket-name/02_clean/echanges_france_detail.parquet
# Optionnel : agrégat annuel import/export. Si absent, chemin dérivé de
# S3_PATH_ECHANGES (même dossier, echanges_annuels_import_export.parquet).
# S3_PATH_ECHANGES_ANNUELS_IMPORT_EXPORT=s3://your-bucket-name/02_clean/echanges_annuels_import_export.parquet
S3_PATH_RTE_EOLIEN_PRODUCTION=s3://your-bucket-name/01_downloaded/portail_analyse_et_donnees/rte_eolien_production_mensuelle.parquet
S3_PATH_RTE_EOLIEN_FACTEUR_CHARGE=s3://your-bucket-name/01_downloaded/portail_analyse_et_donnees/rte_eolien_facteur_charge_mensuel.parquet
S3_PATH_RTE_SOLAIRE_PRODUCTION=s3://your-bucket-name/01_downloaded/portail_analyse_et_donnees/rte_solaire_production_mensuelle.parquet
S3_PATH_RTE_SOLAIRE_FACTEUR_CHARGE=s3://your-bucket-name/01_downloaded/portail_analyse_et_donnees/rte_solaire_facteur_charge_mensuel.parquet

# OIDC Configuration (any OpenID Connect provider, e.g. Zitadel)
# OIDC_ISSUER is the IdP base URL — endpoints are discovered automatically
# via {OIDC_ISSUER}/.well-known/openid-configuration
OIDC_ISSUER=https://your-instance.zitadel.cloud
OIDC_CLIENT_ID=your_client_id_here
OIDC_CLIENT_SECRET=your_client_secret_here
# OIDC_SCOPES=openid profile email
# OIDC_UI_LOCALES=fr  # langue forcée de la page de login (vide = langue du navigateur)
# PAT d'un service user Zitadel (rôle Org User Manager) — active le bouton
# « Supprimer mon compte » (suppression de l'utilisateur chez l'IdP).
# Optionnel : vide => fonctionnalité masquée. Zitadel-spécifique ; le PAT expire.
# ZITADEL_SERVICE_TOKEN=

# Chatbot (Mistral API)
MISTRAL_API_KEY=your_mistral_api_key_here
# CHAT_MODEL=mistral-medium-latest
# CHAT_MAX_TURNS=30

# API publique v1 — clés d'API (Bearer)
# Liste des clés AUTORISÉES, stockées sous forme de HASH SHA-256 (jamais en clair).
# Format : "libelle:hash,libelle2:hash2". Générer une clé :
#   python manage.py generate_api_key alice
# Vide en prod => API fermée (401). Vide en dev (DEBUG=True) => API ouverte.
# API_KEYS=
# Nombre de proxys de confiance devant l'app (Clever Cloud=1) — fiabilise l'IP du throttling.
# NINJA_NUM_PROXIES=1
# Seuils de débit de l'API (par clé). Défauts : 1 req / 2 s en rafale, 5/min soutenu.
# Le multiplicateur est supporté (ex. "1/2s" = 1 requête toutes les 2 secondes).
# API_THROTTLE_BURST=1/2s
# API_THROTTLE_SUSTAINED=5/min
# Plage max (jours) par requête sur les courbes (courbe_*/echange). Défaut : 366.
# Borne le volume de points (pas 15/30 min) pour éviter un pic RAM par requête.
# API_MAX_RANGE_DAYS=366

# Local Parquet cache (optional)
# Directory where Parquet files are downloaded from S3 at startup.
# PARQUET_CACHE_DIR=/tmp/parquet_cache
# How often (seconds) to re-check S3 ETags for freshness. Default: 600.
# Safety net for requests only — the background thread below normally keeps the cache warm.
# PARQUET_CACHE_CHECK_TTL=600
# Background refresh interval (seconds). 0 = one-shot warm-up only. Default: 600.
# PARQUET_CACHE_REFRESH_INTERVAL=600
